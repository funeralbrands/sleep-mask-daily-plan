# Copy this file to ".env" for LOCAL testing only. .env is gitignored.
# In production these live as GitHub Actions repository secrets, NOT in any file.

# Required — Notion internal integration token (starts with "ntn_" or "secret_")
NOTION_TOKEN=

# Required — your Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=

# Optional — enables a richer, AI-written DETAILS section
ANTHROPIC_API_KEY=
# Optional — override the model used for the DETAILS section
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — set to true locally to bypass the "only at 9 AM Eastern" gate
FORCE_SEND=true
